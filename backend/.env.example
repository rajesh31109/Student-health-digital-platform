# =====================================================================
# NODE ENVIRONMENT
# =====================================================================
NODE_ENV=development
PORT=3001

# =====================================================================
# SUPABASE CONFIGURATION
# =====================================================================
# Get these from your Supabase project dashboard
# https://app.supabase.com > Project Settings > API

# Supabase Project URL (e.g., https://xxxx.supabase.co)
SUPABASE_URL=your_supabase_url_here

# Supabase Anon Key (public key for client)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (private key - KEEP SECRET!)
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# For backward compatibility (deprecated but supported)
SUPABASE_KEY=your_supabase_key_here

# =====================================================================
# JWT CONFIGURATION
# =====================================================================
# Secret key for signing JWT tokens (use strong random 32+ character string)
# Generate with: openssl rand -base64 32
JWT_SECRET=your_random_jwt_secret_key_here_min_32_chars

# =====================================================================
# FRONTEND CONFIGURATION
# =====================================================================
# Frontend URL for CORS (allows frontend to make API requests)
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# =====================================================================
# ADMIN CREDENTIALS (Initial Setup)
# =====================================================================
# Email and password for the DMHO (District Medical Health Officer) admin user
ADMIN_EMAIL=rajeshpulluri333@gmail.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=DMHO

# =====================================================================
# DEFAULT SCHOOL CONFIGURATION
# =====================================================================
# Used for generating unique student IDs: {STATE}-{DISTRICT}-{SCHOOL}-{SEQUENCE}
# Example Student ID: TG-01-1968-0001
DEFAULT_STATE_CODE=TG
DEFAULT_DISTRICT_CODE=01
DEFAULT_SCHOOL_CODE=1968

# =====================================================================
# LOGGING CONFIGURATION
# =====================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# =====================================================================
# EMAIL CONFIGURATION (Optional - for future notifications)
# =====================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@schoolhealth.com
